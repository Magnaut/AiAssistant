<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <Folder Include="Agents\Base\" />
    <Folder Include="Agents\Orchestrator\" />
    <Folder Include="Agents\SubAgents\" />
    <Folder Include="Config\" />
    <Folder Include="MCP\Client\" />
    <Folder Include="MCP\Registry\" />
    <Folder Include="MCP\Bridges\" />
    <Folder Include="Modules\Avatar\" />
    <Folder Include="Data\" />
    <Folder Include="Plugins\Hooks\" />
    <Folder Include="Plugins\Extensions\" />
    <Folder Include="Resources\" />
    <Folder Include="UI\Views\" />
    <Folder Include="UI\Controls\" />
    <Folder Include="UI\Converters\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.7" />
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="System.Speech" Version="10.0.7" />
    <PackageReference Include="Vosk" Version="0.3.38" />
  </ItemGroup>
	
  <ItemGroup>
	<!-- Копирование папки Models в выходную директорию -->
	<Content Include="Models\**\*.*">
		<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	</Content>
  </ItemGroup>
	
</Project>
