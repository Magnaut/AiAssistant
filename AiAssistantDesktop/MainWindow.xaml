<Window x:Class="AiAssistantDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Michelle AI Assistant" Height="450" Width="600"
        Background="#1E1E1E">
    <!-- Тёмная тема -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Статус бар -->
        <TextBlock Name="lblStatus" 
                   Text="🟢 Система активна" 
                   FontSize="16" 
                   Foreground="#4CAF50" 
                   FontWeight="Bold" 
                   Margin="0,0,0,10"/>

        <!-- Область лога -->
        <TextBox Name="txtLog" 
                 Grid.Row="1" 
                 IsReadOnly="True" 
                 VerticalScrollBarVisibility="Auto"
                 Background="#252526" 
                 Foreground="#D4D4D4" 
                 FontFamily="Consolas" 
                 FontSize="12" 
                 Padding="10" 
                 Margin="0,10"
                 TextWrapping="Wrap"/>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">

            <Button Name="btnToggleListen" 
                    Content="⏹ Остановить" 
                    Width="130" 
                    Height="35" 
                    FontSize="14"
                    Click="BtnToggleListen_Click" 
                    Margin="0,0,10,0"/>

            <Button Name="btnClearLog" 
                    Content="🗑 Очистить" 
                    Width="100" 
                    Height="35" 
                    Click="BtnClearLog_Click"/>
        </StackPanel>
    </Grid>
</Window>