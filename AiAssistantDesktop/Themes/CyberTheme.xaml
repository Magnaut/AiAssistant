<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BgBrush" Color="#0A0A0F"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#111118"/>
    <SolidColorBrush x:Key="TextBrush" Color="#00FF9C"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF0055"/>
    <SolidColorBrush x:Key="ButtonBrush" Color="#1A1A24"/>
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="#00FF9C"/>
    </Style>
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="#FF0055"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
</ResourceDictionary>