<Window x:Class="AiAssistantDesktopDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Michelle AI Assistant" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Лог диалога -->
        <ScrollViewer x:Name="LogScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="txtLog" FontSize="14" TextWrapping="Wrap" 
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     BorderThickness="0" Background="Transparent"
                     Focusable="False"/>
        </ScrollViewer>

        <!-- Статус -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock x:Name="txtStatus" FontWeight="Bold" Foreground="Gray"/>
            <TextBlock x:Name="txtThinking" Foreground="Blue" Margin="10,0" Visibility="Collapsed">🔄 Думаю...</TextBlock>
        </StackPanel>

        <!-- Ввод и кнопка -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBox x:Name="txtInput" Height="30" VerticalContentAlignment="Center" 
                     FontSize="14" Margin="0,0,10,0" Width="600"
                     KeyDown="TxtInput_KeyDown"/>
            <Button x:Name="btnSend" Content="➤" Width="50" Click="BtnSend_Click"/>
            <Button x:Name="btnToggleListen" Content="🎤" Width="50" Margin="5,0" 
                    Click="BtnToggleListen_Click"/>
        </StackPanel>
    </Grid>
</Window>